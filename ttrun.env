# Keycloak
AUTH_SECRET={{vault://secret/services/elephant-chrome/auth.AUTH_SECRET}}
AUTH_KEYCLOAK_ID={{vault://secret/services/elephant-chrome/auth.AUTH_KEYCLOAK_ID}}
AUTH_KEYCLOAK_SECRET={{vault://secret/services/elephant-chrome/auth.AUTH_KEYCLOAK_SECRET}}
AUTH_KEYCLOAK_ISSUER={{vault://secret/services/elephant-chrome/auth.AUTH_KEYCLOAK_ISSUER}}
AUTH_TRUST_HOST=http://localhost:5173
AUTH_POST_LOGOUT_URI=http://localhost:5173/elephant
# Redis cache
REDIS_URL=rediss://{{vault://secret/services/elephant-chrome/redis.username}}:{{vault://secret/services/elephant-chrome/redis.password}}@{{vault://secret/services/elephant-chrome/redis.address}}:6379
# Services
INDEX_URL={{vault://secret/elephant-dev-urls.INDEX_URL}}
WS_URL=ws://localhost:5173/elephant/ws
REPOSITORY_URL={{vault://secret/elephant-dev-urls.REPOSITORY_URL}}
SPELLCHECK_URL={{vault://secret/elephant-dev-urls.SPELLCHECK_URL}}
BABOON_URL={{vault://secret/elephant-dev-urls.BABOON_URL}}
CONTENT_API_URL={{vault://secret/elephant-dev-urls.CONTENT_API_URL}}
USER_URL={{vault://secret/elephant-dev-urls.USER_URL}}
# Server
PROTOCOL=http
HOST=localhost
PORT=5173
BASE_URL=/elephant
LOG_LEVEL=debug
# Images
IMAGE_BASE_URL={{vault://secret/elephant-dev-urls.IMAGE_BASE_URL}}
GRAPHIC_BASE_URL={{vault://secret/elephant-dev-urls.GRAPHIC_BASE_URL}}
IMAGE_SEARCH_PROVIDER=ntb
IMAGE_SEARCH_URL=https://mediamanager.api.stage.tt.se
#IMAGE_SEARCH_URL={{vault://secret/elephant-dev-urls.IMAGE_SEARCH_URL}}
# Observability
FARO_URL={{vault://secret/elephant-dev-urls.FARO_URL}}
FARO_NAME=elephant-chrome-localhost-gvl
PYROSCOPE_URL=
# Client credentials
ELEPHANT_CHROME_CLIENT_ID={{vault://secret/services/elephant-chrome/auth.ELEPHANT_CHROME_CLIENT_ID}}
ELEPHANT_CHROME_CLIENT_SECRET={{vault://secret/services/elephant-chrome/auth.ELEPHANT_CHROME_CLIENT_SECRET}}
#VITE_ENV=local-gvl
SYSTEM_LANGUAGE=nb-NO